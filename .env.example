# Paper Agent 环境变量配置示例
# 复制此文件为 .env，然后填入你的真实 API Key

# 服务端端口
PORT=3000

# CodeBuddy API Key
# 获取方式：访问 https://copilot.tencent.com/profile/ 登录后创建 API Key
CODEBUDDY_API_KEY=your_api_key_here

# 网络环境配置
# internal = 中国版 (copilot.tencent.com)
# external = 海外版 (www.codebuddy.ai)
# ioa = 腾讯内网版
CODEBUDDY_INTERNET_ENVIRONMENT=internal
